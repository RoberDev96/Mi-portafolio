---
import FooterMain from "../components/shared/footerMain.astro";
import MyPerfil from "../components/shared/myPerfil.astro";
import SocialFav from "../components/shared/socialFav.astro";
import Swiper from "../components/shared/swiper.astro";
import Layout from "../layout/Layout.astro";


---

<Layout>
  <div class="flex flex-col mt-44 gap-10 items-center w-full">
    <section class="flex flex-col justify-center align-middle">
      <div
        class="w-137.5 flex flex-col flex-wrap text-center items-center gap-3"
      >
        <h1
          class="text-[#F9FAFB] [text-shadow:0_4px_6px_#3B82F6] text-6xl font-bold"
        >
          Hola! soy Roberto
        </h1>

        <div class="h-20 flex justify-center items-center">
          <div class="typewriter-container">
            <h2
              class="text-[#3B82F6] text-3xl text-center font-bold typewriter-text"
            >
              Desarrollador Frontend...
            </h2>
          </div>
        </div>

        <p class="text-white text-xl font-bold max-w-2xl">
          Explora mis proyectos, conoce un poco más sobre mí y, si deseas
          ponerte en contacto, ¡estoy a solo un mensaje de distancia!
        </p>
      </div>

      <aside class="flex justify-center mt-8 items-center">
        <a href="../../public/Roberto-Romero.pdf" download>
          <button
            class="bg-[#2563EB] w-52 h-11 rounded-4xl shadow-[3px_3px_0_#1E40AF]
            hover:bg-[#1D4ED8] hover:scale-105 hover:shadow-[1px_1px_0_#1E40AF]
            hover:translate-x-0.5 hover:translate-y-0.5
            transition-all duration-200 text-white font-bold cursor-pointer"
          >
            Curriculum
          </button>
        </a>
      </aside>
    </section>

    <section>
      <SocialFav />
      <Swiper />
    </section>

    <section>
    <MyPerfil />

      
    </section>

    <footer class="h-36 w-full">
      <FooterMain />
    </footer>
  </div>
</Layout>

<style>
  .typewriter-container {
    display: inline-block;
  }

  .typewriter-text {
    overflow: hidden;
    white-space: nowrap;
    border-right: 3px solid #3b82f6;
    display: inline-block;
    animation: typewriter 10s steps(30, end) infinite;
    width: 0;
  }

  @keyframes typewriter {
    0% {
      width: 0;
    }
    20% {
      width: 100%;
    }
    50% {
      width: 100%;
    }
    70% {
      width: 0;
    }
    100% {
      width: 0;
    }
  }

  @keyframes blink-caret {
    from,
    to {
      border-color: transparent;
    }
    50% {
      border-color: #3b82f6;
    }
  }
</style>
