---
import { svgX } from '../../icons/iconsTab/tab';
import { svgLinkedin } from '../../icons/iconsTab/tab';
import { svgFacekook } from '../../icons/iconsTab/tab';
import { svgGitHub } from '../../icons/iconsTab/tab';
import { svgTelegram } from '../../icons/iconsTab/tab';

const redes = [
  { icon: svgX, url: "https://x.com/Roberto04257535", name: "X (Twitter)" },
  { icon: svgLinkedin, url: "https://www.linkedin.com/in/roberto-romero-b188a53b3/", name: "LinkedIn" },
  { icon: svgFacekook, url: "https://www.facebook.com/profile.php?id=100010800663607", name: "Facebook" },
  { icon: svgGitHub, url: "https://github.com/RoberDev96", name: "GitHub" },
  { icon: svgTelegram, url: "https://t.me/LinkinPark_RRD", name: "Telegram" },
];
---

<div class="fab-container hidden md:block">
  <button id="fab" class="fab-btn" aria-label="Abrir menú de redes sociales">+</button>

  <div id="fab-menu" class="fab-menu font-bold">
    {redes.map((r) => (
      <a 
        href={r.url} 
        target="_blank" 
        class="fab-item" 
        set:html={r.icon}
        aria-label={r.name}
        rel="noopener noreferrer"
      >
      </a>
    ))}
  </div>
</div>

<style>
  .fab-container {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 999;
  }

  .fab-btn {
    background: #2563EB;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    color: white;
    font-size: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 3px 3px 0 #1E40AF;
    transition: transform 0.2s ease;
  }

  .fab-btn:hover {
    transform: scale(1.08);
  }

  .fab-menu {
    position: absolute;
    bottom: 70px;
    right: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .fab-item {
    background: white;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    box-shadow: 0 4px 8px rgba(0,0,0,0.2);
    transition: transform 0.2s ease, opacity 0.2s ease;
    transform: scale(0);
    opacity: 0;
    cursor: pointer;
    text-decoration: none;
  }

  .fab-item.open {
    transform: scale(1);
    opacity: 1;
  }

  .fab-item:hover {
    background: #2563EB;
  }

  .fab-item:hover svg {
    fill: white;
    stroke: white;
  }
</style>

<script is:raw>
  const fab = document.getElementById("fab");
  const menu = document.getElementById("fab-menu");

  if (fab && menu) {
    const items = menu.querySelectorAll(".fab-item");

    fab.addEventListener("click", () => {
      items.forEach((item, i) => {
        setTimeout(() => {
          item.classList.toggle("open");
        }, i * 60);
      });
    });

    document.addEventListener("click", (event) => {
      if (!fab.contains(event.target) && !menu.contains(event.target)) {
        items.forEach((item) => {
          item.classList.remove("open");
        });
      }
    });
  }
</script>