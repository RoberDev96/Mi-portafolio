---
import {svgX} from '../../icons/iconsTab/tab';
import {svgLinkedin} from '../../icons/iconsTab/tab';
import {svgFacekook} from '../../icons/iconsTab/tab';
import {svgGitHub} from '../../icons/iconsTab/tab';
import {svgTelegram} from '../../icons/iconsTab/tab';


const redes = [
  { icon: svgX, url: "https://x.com/Roberto04257535" },
  { icon: svgLinkedin, url: "https://www.linkedin.com/in/roberto-romero-b188a53b3/" },
  { icon: svgFacekook, url: "https://www.facebook.com/profile.php?id=100010800663607" },
  { icon: svgGitHub , url: "https://github.com/RoberDev96" },
  { icon: svgTelegram , url: "https://t.me/LinkinPark_RRD" },

];

---

<div class="fab-container hidden md:block ">
  <button id="fab" class="fab-btn">+</button>

  <div id="fab-menu" class="fab-menu font-bold">
    {redes.map((r) => (
      <a href={r.url} target="_blank" class="fab-item" set:html={r.icon}>{r.icon}</a>
    ))}
  </div>
</div>

<style>
  .fab-container {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 999;
  }

  .fab-btn {
    background: #2563EB;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    color: white;
    font-size: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 3px 3px 0 #1E40AF;
    transition: transform 0.2s ease;
  }

  .fab-btn:hover {
    transform: scale(1.08);
  }

  .fab-menu {
    position: absolute;
    top: -5px;
    transform: translateX(-50%);
  }

  .fab-item {
    position: absolute;
    background: white;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    box-shadow: 0 2px 6px rgba(0,0,0,0.2);
    transform: translateY(0) scale(0);
    transition: transform 0.35s ease;
    cursor: pointer;
  }

  .fab-item.open {
    transform: translateY(var(--ty)) scale(1);
  }
</style>

<script is:raw>
  const fab = document.getElementById("fab");
  const menu = document.getElementById("fab-menu");

  if (fab && menu) {
    const items = menu.querySelectorAll(".fab-item");
    const spacing = 60; // distancia entre iconos

    items.forEach((item, i) => {
      const offset = -(i + 1) * spacing; // hacia arriba
      item.style.setProperty("--ty", `${offset}px`);
    });

    fab.addEventListener("click", () => {
      items.forEach((item, i) => {
        setTimeout(() => {
          item.classList.toggle("open");
        }, i * 60);
      });
    });
  }
</script>
