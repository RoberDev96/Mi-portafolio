---
import { Icon } from "astro-icon/components";
import { useState } from "react";

interface NavItem {
  href: string;
  text: string;
}

const nav: NavItem[] = [
  { href: "/", text: "Inicio" },
  { href: "/proyectos/proyectos", text: "Proyectos" },
  { href: "/sobreMi/sobreMi", text: "Sobre Mi" },
];
---

<section>
  <nav
    class="fixed top-0 left-0 flex justify-between items-center border-b border-white/10 w-full px-4 md:px-6 
    bg-[#030712]/80 backdrop-blur-md z-50 h-16 md:h-auto"
  >
    
    <!-- Logo o marca (opcional) -->
    <div class="text-white font-bold text-xl md:hidden">
      Portfolio
    </div>

    <!-- Menú desktop - visible en pantallas grandes -->
    <ol class="hidden md:flex justify-center gap-6 lg:gap-10 m-4 md:m-6">
      {
        nav.map((item) => (
          <li>
            <a
              class="text-white font-bold text-[16px] font-serif hover:text-[#3B82F6] 
              scale-105 duration-300 inline-block transition-colors"
              href={item.href}
            >
              {item.text}
            </a>
          </li>
        ))
      }
    </ol>

    <!-- Iconos de redes sociales - siempre visibles en desktop -->
    <div class="hidden md:flex gap-5 items-center">
      <a
        href="https://github.com/RoberDev96"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:bg-[#3B82F6] transition-opacity flex items-center justify-center w-9 h-9 rounded-full"
      >
        <Icon name="gitHub" size={30} class="text-white" />
      </a>
      <a
        href="https://web.telegram.org/k/#@LinkinPark_RRD"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-[#3B82F6] opacity-80 transition-opacity flex items-center justify-center w-9 h-9 rounded-full"
      >
        <Icon name="telegram" size={30} class="text-white" />
      </a>
      <a
        href="https://t.me/LinkinPark_RRD"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:bg-[#3B82F6] opacity-80 transition-opacity flex items-center justify-center w-9 h-9 rounded-full"
      >
        <Icon name="linkedin" size={30} class="text-white" />
      </a>
    </div>

    <!-- Botón menú hamburguesa - solo visible en móvil -->
    <div class="md:hidden flex items-center gap-3">
      <!-- Redes sociales en móvil compacto -->
      <a
        href="https://github.com/RoberDev96"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:bg-[#3B82F6] transition-opacity flex items-center justify-center w-8 h-8 rounded-full"
      >
        <Icon name="gitHub" size={24} class="text-white" />
      </a>
      
      <button
        id="menu-btn"
        class="text-white focus:outline-none hover:text-[#3B82F6] transition-colors"
        aria-label="Menú"
      >
        <svg
          id="menu-icon"
          class="w-8 h-8"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"
          />
        </svg>
      </button>
    </div>

    <!-- Menú desplegable móvil -->
    <div
      id="mobile-menu"
      class="hidden fixed top-16 left-0 w-full bg-[#030712]/95 backdrop-blur-md border-b border-white/10 md:hidden flex-col items-center py-6 gap-4 z-40"
    >
      {
        nav.map((item) => (
          <a
            class="text-white font-bold text-lg font-serif hover:text-[#3B82F6] 
            transition-colors py-2 px-4 text-center w-full"
            href={item.href}
          >
            {item.text}
          </a>
        ))
      }
      <!-- Redes sociales dentro del menú móvil -->
      <div class="flex gap-6 mt-4 pt-4 border-t border-white/20 w-full justify-center">
        <a
          href="https://github.com/RoberDev96"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-[#3B82F6] transition-colors"
        >
          <Icon name="gitHub" size={28} class="text-white" />
        </a>
        <a
          href="https://web.telegram.org/k/#@LinkinPark_RRD"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-[#3B82F6] transition-colors"
        >
          <Icon name="telegram" size={28} class="text-white" />
        </a>
        <a
          href="https://t.me/LinkinPark_RRD"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-[#3B82F6] transition-colors"
        >
          <Icon name="linkedin" size={28} class="text-white" />
        </a>
      </div>
    </div>
  </nav>
</section>

<script>
  (function() {
    const menuBtn = document.getElementById('menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');

    // Función para cambiar el ícono
    function changeIcon(isOpen: boolean) {
      if (menuIcon) {
        if (isOpen) {
          menuIcon.innerHTML = `
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          `;
        } else {
          menuIcon.innerHTML = `
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          `;
        }
      }
    }

    if (menuBtn && mobileMenu) {
      menuBtn.addEventListener('click', () => {
        const isHidden = mobileMenu.classList.contains('hidden');
        
        if (isHidden) {
          mobileMenu.classList.remove('hidden');
          changeIcon(true);
        } else {
          mobileMenu.classList.add('hidden');
          changeIcon(false);
        }
      });

      const mobileLinks = mobileMenu.querySelectorAll('a');
      mobileLinks.forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu.classList.add('hidden');
          changeIcon(false);
        });
      });
    }

    let resizeTimer: ReturnType<typeof setTimeout> | null = null;
    window.addEventListener('resize', () => {
      if (resizeTimer !== null) {
        clearTimeout(resizeTimer);
      }
      resizeTimer = setTimeout(() => {
        if (window.innerWidth >= 768 && mobileMenu && !mobileMenu.classList.contains('hidden')) {
          mobileMenu.classList.add('hidden');
          changeIcon(false);
        }
        resizeTimer = null;
      }, 250);
    });
  })();
</script>

<style>
  #mobile-menu {
    transition: all 0.3s ease-in-out;
  }
  
  #mobile-menu.hidden {
    display: none;
  }
</style>